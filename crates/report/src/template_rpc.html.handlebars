<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Contender RPC Report</title>

  <style>
    @font-face {
      font-family: 'CMU-Serif';
      src: url('https://fonts.cdnfonts.com/s/19926/cmunbx.woff') format('woff');
      font-style: normal;
      font-weight: bold;
      font-stretch: normal;
    }
    @font-face {
      font-family: 'CMU-Serif';
      src: url('https://fonts.cdnfonts.com/s/19926/cmunci.woff') format('woff');
      font-style: italic;
      font-weight: 400;
      font-stretch: normal;
    }
    @font-face {
      font-family: 'CMU-Serif';
      src: url('https://fonts.cdnfonts.com/s/19926/cmunrm.woff') format('woff');
      font-style: normal;
      font-weight: 400;
      font-stretch: normal;
    }

    * {
      box-sizing: border-box;
    }

    body,
    html {
      padding: 0;
      margin: 0;
    }

    body {
      font-family: 'CMU-Serif', serif;
      overflow-x: hidden;
      display: flex;
      flex-direction: column;
      align-items: center;
      color: #0D0D0D;
    }

    header {
      padding: 4rem 1rem 2rem;
      text-align: center;
    }

    header p {
      margin: 0;
      line-height: 1.6;
    }

    header p:first-of-type {
      margin-bottom: 1rem;
    }

    section {
      width: 100%;
      max-width: 40rem;
      padding: 2rem 1rem;
    }

    h1 {
      color: #0D0D0D;
      text-align: center;
      font-size: 2.5rem;
      font-style: normal;
      font-weight: 500;
      line-height: 1.2;
    }

    h2 {
      font-size: 1.1rem;
      text-align: center;
      text-transform: uppercase;
      padding: 1rem 0 .5rem;
    }

    a {
      color: blue;
      text-decoration: none;
    }

    a:hover {
      text-decoration: underline;
    }

    .metrics {
      display: flex;
      justify-content: space-between;
      margin-top: 2rem;
    }

    .metrics p b {
      font-size: 1.1rem;
    }

    .label {
      font-size: .9rem;
      font-style: italic;
      color: #3c3c3c;
    }

    table {
      width: 100%;
    }

    th {
      text-align: left;
      font-weight: bold;
      line-height: 1.8;
      border-bottom: solid 1px #d7d7d7;
    }

    td {
      line-height: 1.5;
    }

    footer p {
      text-align: center;
      font-size: .9rem;
      padding: 1rem;
    }

    .chart {
      width: 100%;
      height: 420px;
    }
  </style>

</head>

<body>
  <header>
    <h1>Flashbots <br /> RPC Performance Report</h1>
    <p><i>{{data.date}}</i></p>
    <br />
    <p>Method: <b>{{data.method}}</b></p>
    <a href="{{data.rpc_url}}" target="_blank">
      <p>Target RPC</p>
    </a>
  </header>

  <section>
    <h2>Summary</h2>
      <div style="display: flex; justify-content: space-between;">
        <div>
          <p>Total Requests:</p>
          <p><b>{{data.total_requests}}</b></p>
        </div>
        <div>
          <p>Success:</p>
          <p><b>{{data.success_count}}</b></p>
        </div>
        <div>
          <p>Errors:</p>
          <p><b>{{data.error_count}}</b></p>
        </div>
      </div>
      <div style="display: flex; justify-content: space-between; margin-top: 1rem;">
        <div>
          <p>Requests/sec:</p>
          <p><b>{{data.rps}}</b></p>
        </div>
        <div>
          <p>Duration:</p>
          <p><b>{{data.duration_secs}}s</b></p>
        </div>
      </div>
  </section>

  <section>
    <h2>RPC Response Latency</h2>
    <table>
      <thead>
        <tr>
          <th>Method</th>
          <th>p50 (ms)</th>
          <th>p90 (ms)</th>
          <th>p99 (ms)</th>
        </tr>
      </thead>
      <tbody>
        <tr>
          <td>{{data.latency_quantiles.method}}</td>
          <td>{{data.latency_quantiles.p50}}</td>
          <td>{{data.latency_quantiles.p90}}</td>
          <td>{{data.latency_quantiles.p99}}</td>
        </tr>
      </tbody>
    </table>
  </section>

  {{!-- ==================== Charts ==================== --}}

  <section>
    <h2>{{data.method}} Latency</h2>
    <div class="chart" id="method-latency"></div>
  </section>

  {{!-- ==================== ====== ==================== --}}

  <footer>
    <p>Flashbots 2025 &copy; &middot; Contender v{{data.version}}</p>
  </footer>

  <script src="https://cdnjs.cloudflare.com/ajax/libs/echarts/5.6.0/echarts.min.js" integrity="sha512-XSmbX3mhrD2ix5fXPTRQb2FwK22sRMVQTpBP2ac8hX7Dh/605hA2QDegVWiAvZPiXIxOV0CbkmUjGionDpbCmw==" crossorigin="anonymous" referrerpolicy="no-referrer"></script>
  <script type="text/javascript">
    if (typeof echarts === 'undefined') {
      throw new Error('ECharts library is not loaded. Please include the ECharts script.');
    }

    async function renderMethodLatency() {
      var chart = echarts.init(document.getElementById('method-latency'));

      const buckets = [{{#each data.latency_chart.buckets}}"{{this}}"{{#if @last}}{{else}}, {{/if}}{{/each}}];
      const counts = {{data.latency_chart.counts}};
      const p50 = {{data.latency_chart.quantiles.p50}}.toPrecision(3);
      const p90 = {{data.latency_chart.quantiles.p90}}.toPrecision(3);
      const p99 = {{data.latency_chart.quantiles.p99}}.toPrecision(3);

      var option = {
        tooltip: {
          trigger: 'axis',
          axisPointer: {
            type: 'shadow'
          }
        },
        grid: {
          right: '15%',
        },
        xAxis: {
          type: 'category',
          data: buckets,
          name: 'Latency (ms)',
          axisLabel: {
            interval: 0,
            rotate: 45
          }
        },
        yAxis: {
          type: 'value',
          name: 'Num. Requests',
          min: 0,
          max: Math.max(...counts),
        },
        visualMap: false,
        graphic: [
          {
            type: 'group',
            left: '75%',
            top: '10%',
            draggable: true,
            children: [
              {
                type: 'rect',
                shape: { width: 110, height: 65 },
                z: 10,
                style: {
                  fill: '#fffbe6',
                  stroke: '#fac858',
                  lineWidth: 1,
                  shadowBlur: 4,
                  shadowColor: 'rgba(250,200,88,0.2)'
                }
              },
              {
                type: 'text',
                left: 10,
                top: 10,
                z: 11,
                style: {
                  text: `p50: ${p50} ms\np90: ${p90} ms\np99: ${p99} ms`,
                  font: '14px CMU-Serif, serif',
                  fill: '#333'
                }
              }
            ]
          }
        ],
        series: [{
          name: '{{data.method}}',
          type: 'bar',
          data: counts,
          itemStyle: {
            color: '#fac858'
          }
        }]
      };

      chart.setOption(option);
    }

    renderMethodLatency();
  </script>

</body>
</html>
